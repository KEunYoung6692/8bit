# Server-side Supabase/Postgres connection values.
# Do not expose these with a VITE_ prefix.
host=aws-1-ap-northeast-2.pooler.supabase.com
port=6543
database=postgres
user=postgres.YOUR_PROJECT_REF
password=YOUR_DATABASE_PASSWORD

# Optional AI API key. Keep server-side unless you intentionally expose it.
GOOGLE_AI_API_KEY=YOUR_GOOGLE_AI_API_KEY
